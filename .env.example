# VIN-Sight — Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ── Required ─────────────────────────────────────────────────────────────────
# None! The app works fully with zero API keys.
# NHTSA VIN decoder and Recalls API are 100% free with no key required.

# ── Optional ─────────────────────────────────────────────────────────────────
# PORT: The port to run the Express server on (default: 3000)
# PORT=3000

# NODE_ENV: Set to "production" when deploying
# NODE_ENV=production
